# Runtime
NOVELCRAFT_ENV=development
NOVELCRAFT_JWT_SECRET=replace-with-at-least-32-random-bytes
NOVELCRAFT_CREDENTIALS_KEY=
DATABASE_URL=postgresql://novelcraft:novelcraft@localhost:5432/novelcraft
REDIS_URL=redis://localhost:6379/0

# AI providers. Interactive browser BYOK can override these per request;
# workers/scheduled jobs always use env values.
NOVELCRAFT_AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
CLAUDE_API_KEY=
CLAUDE_API_URL=https://api.anthropic.com/v1/messages
OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1/chat/completions
GEMINI_API_KEY=
GEMINI_API_URL=
# Extra trusted provider hosts for private OpenAI-compatible gateways (hostnames only).
AI_API_BASE_HOST_ALLOWLIST=
AI_CALL_RETENTION_DAYS=365
OPERATION_LOG_RETENTION_DAYS=180
AUDIT_LOG_RETENTION_DAYS=365

# Semantic embedding defaults to local BGE when fastembed is installed.
EMBEDDING_BACKEND=auto
EMBEDDING_LOCAL_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_API_KEY=
EMBEDDING_API_URL=

# Hotspot source overrides / proxy. Prefer Settings → 平台连接 for per-user
# URLs/cookies/tokens; env values are service-wide defaults.
HOTSPOT_HTTP_PROXY=
HOTSPOT_XIAOHONGSHU_URL=
HOTSPOT_DOUYIN_URL=
HOTSPOT_X_URL=
HOTSPOT_BAIDU_COOKIE=
HOTSPOT_ZHIHU_COOKIE=
HOTSPOT_WEIBO_COOKIE=
HOTSPOT_XIAOHONGSHU_COOKIE=
HOTSPOT_DOUYIN_COOKIE=
HOTSPOT_X_COOKIE=

# Ops / observability
SENTRY_DSN=
METRICS_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Publish adapters
MEDIUM_USER_ID=
WORDPRESS_DEFAULT_URL=

# Admin access: comma-separated emails. Writes to /admin/* always require it;
# when set, /admin reads (prompts/model-routes/providers) are restricted too.
# Leave empty on a single-user personal instance to keep reads available.
NOVELCRAFT_ADMIN_EMAILS=

# Browser session security
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
TOKEN_BLACKLIST_FAIL_CLOSED=true
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ACCESS_TOKEN_EXP_MINUTES=30
REFRESH_TOKEN_EXP_DAYS=30

# Flower is bound to 127.0.0.1 but still requires authentication
FLOWER_USER=admin
FLOWER_PASSWORD=replace-with-a-long-random-password
