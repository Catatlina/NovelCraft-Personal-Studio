# NovelCraft production .env — Singapore host (43.156.17.78).
# Copy to `.env` next to docker-compose.yml and fill every <...> value.
# In production mode the app REFUSES to start if the required secrets are missing
# or weak (see backend/app/config.py __post_init__).

# ---- Runtime (required) ----
NOVELCRAFT_ENV=production
# 32+ chars. Generate:  openssl rand -hex 32
NOVELCRAFT_JWT_SECRET=<openssl rand -hex 32>
# Fernet key that encrypts publishing platform credentials. Required in prod.
# Generate:  python3 -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
NOVELCRAFT_CREDENTIALS_KEY=<fernet-key>

# ---- Browser session security (HTTPS terminates at nginx) ----
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
TOKEN_BLACKLIST_FAIL_CLOSED=true
# Must match the public origin exactly (scheme + host).
CORS_ORIGINS=https://app.example.com

# ---- Datastores (compose-internal) ----
POSTGRES_PASSWORD=<strong-db-password>
# DATABASE_URL / REDIS_URL are set by docker-compose; no need to override.

# ---- AI provider ----
# Either set a server-side key here, or leave blank and use per-user BYOK in the UI.
DEEPSEEK_API_KEY=<deepseek-key-or-blank>
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ---- Memory tuning for a 3.6G box (IMPORTANT) ----
# Do NOT run the local BGE model here (onnxruntime resident ~300-500M). Use hash
# (offline, non-semantic) or point EMBEDDING at a remote OpenAI-compatible API.
EMBEDDING_BACKEND=hash
# For real semantic search instead, set:
#   EMBEDDING_BACKEND=remote
#   EMBEDDING_API_KEY=<...>
#   EMBEDDING_API_URL=https://api.openai.com/v1
#   EMBEDDING_MODEL=text-embedding-3-small

# ---- Retention (days) ----
AI_CALL_RETENTION_DAYS=365
OPERATION_LOG_RETENTION_DAYS=180
AUDIT_LOG_RETENTION_DAYS=365

# ---- Monitoring (optional; fill to enable real delivery) ----
# Telegram alerts (budget/patrol/publish failures):
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Sentry error tracking (use a free sentry.io DSN; don't self-host on this box).
# Auto-captures unhandled exceptions in both api and worker once set.
SENTRY_DSN=
# Optional: fraction of requests traced for performance (0 = errors only).
SENTRY_TRACES_SAMPLE_RATE=0
# Prometheus /metrics is DISABLED unless BOTH are set; then it requires
# `Authorization: Bearer <METRICS_TOKEN>` (404 otherwise). Leave off if unused.
METRICS_ENABLED=false
METRICS_TOKEN=

# ---- Flower (skipped via --scale flower=0, but keep valid values) ----
FLOWER_USER=admin
FLOWER_PASSWORD=<strong-flower-password>
