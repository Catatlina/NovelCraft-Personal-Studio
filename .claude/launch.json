{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "frontend", "run", "dev"],
      "port": 5173
    },
    {
      "name": "backend",
      "runtimeExecutable": "backend/.venv/bin/uvicorn",
      "runtimeArgs": ["app.main:app", "--reload", "--port", "8000", "--app-dir", "backend"],
      "port": 8000
    },
    {
      "name": "backend-8001",
      "runtimeExecutable": "backend/.venv/bin/uvicorn",
      "runtimeArgs": ["app.main:app", "--reload", "--port", "8001", "--app-dir", "backend"],
      "port": 8001
    },
    {
      "name": "frontend-proxy8001",
      "runtimeExecutable": "env",
      "runtimeArgs": ["VITE_API_PROXY_TARGET=http://127.0.0.1:8001", "npm", "--prefix", "frontend", "run", "dev"],
      "port": 5173
    }
  ]
}
